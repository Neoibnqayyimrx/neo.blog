# ------------------------------------------------------------
# Example environment file. Copy to `.env` and edit values.
# ------------------------------------------------------------

APP_ENV=development
APP_NAME="NEO · BLOG"
APP_TIMEZONE=Africa/Lagos

# Database driver: mysql (production) or sqlite (zero-config local run)
DB_DRIVER=mysql

# MySQL connection (matches docker-compose.yml defaults)
DB_HOST=db
DB_PORT=3306
DB_NAME=php_blog
DB_USER=blog
DB_PASS=blog

# Uploads
MAX_UPLOAD_SIZE=2097152

# Session
SESSION_LIFETIME=7200
